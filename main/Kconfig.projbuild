        default 33 if PCNT_PIN_Z_GPIO_33
        default 34 if PCNT_PIN_Z_GPIO_34
        default 35 if PCNT_PIN_Z_GPIO_35
        default 36 if PCNT_PIN_Z_GPIO_36
        default 39 if PCNT_PIN_Z_GPIO_39

    # Выбор для пина Z ******************************************************************************************

    # Настройкой фильтра помех (glitch filter) ******************************************************************

    config PCNT_GLITCH_FILTER_NS
        int "Glitch filter time (nanoseconds)"
        range 0 12500
        default 2500
        help
            Игнорировать импульсы короче этого времени.
            12500 нс (12.5 мкс) подходит для медленных энкодеров.
            Для скоростных (высокое разрешение или обороты) уменьшите до 1000-5000.

    # Настройкой фильтра помех (glitch filter) ******************************************************************

endmenu
