        default 16 if PCNT_PIN_Z_GPIO_16
        default 17 if PCNT_PIN_Z_GPIO_17
        default 18 if PCNT_PIN_Z_GPIO_18
        default 19 if PCNT_PIN_Z_GPIO_19
        default 21 if PCNT_PIN_Z_GPIO_21
