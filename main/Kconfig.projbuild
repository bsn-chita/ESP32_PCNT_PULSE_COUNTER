    # Выбор для пина B ******************************************************************************************

    # Выбор для пина Z ******************************************************************************************

    choice PCNT_PIN_Z_SELECT
        prompt "Выберите GPIO для нулевой метки Z ( Z-signal / Index)"
        default PCNT_PIN_Z_GPIO_27
        help
