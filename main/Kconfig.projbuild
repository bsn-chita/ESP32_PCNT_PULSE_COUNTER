        config PCNT_PIN_Z_GPIO_16
            bool "GPIO 16"
        config PCNT_PIN_Z_GPIO_17
            bool "GPIO 17"
        config PCNT_PIN_Z_GPIO_18
            bool "GPIO 18"
        config PCNT_PIN_Z_GPIO_19
            bool "GPIO 19"
