menu "Настройки энкодера (PCNT)"

    # Выбор для пина A ******************************************************************************************

    choice PCNT_PIN_A_SELECT
        prompt "Выберите GPIO для Фазы А (Pulse Input - Phase A)"
        default PCNT_PIN_A_GPIO_25
        help
            Выберите один из разрешенных GPIO для фазы A.

        config PCNT_PIN_A_GPIO_16
            bool "GPIO 16"
        config PCNT_PIN_A_GPIO_17
            bool "GPIO 17"
        config PCNT_PIN_A_GPIO_18
            bool "GPIO 18"
        config PCNT_PIN_A_GPIO_19
            bool "GPIO 19"
        config PCNT_PIN_A_GPIO_21
            bool "GPIO 21"
        config PCNT_PIN_A_GPIO_22
            bool "GPIO 22"
        config PCNT_PIN_A_GPIO_23
            bool "GPIO 23"
        config PCNT_PIN_A_GPIO_25
            bool "GPIO 25"
        config PCNT_PIN_A_GPIO_26
            bool "GPIO 26"
        config PCNT_PIN_A_GPIO_27
            bool "GPIO 27"
        config PCNT_PIN_A_GPIO_32
            bool "GPIO 32"
        config PCNT_PIN_A_GPIO_33
            bool "GPIO 33"
        config PCNT_PIN_A_GPIO_34
            bool "GPIO 34 Нет внутренних подтягивающих резисторов. Требуются внешние резисторы 1(4.7)--10кОм к 3.3v"
        config PCNT_PIN_A_GPIO_35
            bool "GPIO 35 Нет внутренних подтягивающих резисторов. Требуются внешние резисторы 1(4.7)--10кОм к 3.3v"
        config PCNT_PIN_A_GPIO_36
            bool "GPIO 36 Нет внутренних подтягивающих резисторов. Требуются внешние резисторы 1(4.7)--10кОм к 3.3v"
        config PCNT_PIN_A_GPIO_39
            bool "GPIO 39 Нет внутренних подтягивающих резисторов. Требуются внешние резисторы 1(4.7)--10кОм к 3.3v"

    endchoice

    config PCNT_PIN_A
        int
        default 16 if PCNT_PIN_A_GPIO_16
        default 17 if PCNT_PIN_A_GPIO_17
        default 18 if PCNT_PIN_A_GPIO_18
        default 19 if PCNT_PIN_A_GPIO_19
        default 21 if PCNT_PIN_A_GPIO_21
        default 22 if PCNT_PIN_A_GPIO_22
        default 23 if PCNT_PIN_A_GPIO_23
        default 25 if PCNT_PIN_A_GPIO_25
        default 26 if PCNT_PIN_A_GPIO_26
        default 27 if PCNT_PIN_A_GPIO_27
        default 32 if PCNT_PIN_A_GPIO_32
        default 33 if PCNT_PIN_A_GPIO_33
        default 34 if PCNT_PIN_A_GPIO_34
        default 35 if PCNT_PIN_A_GPIO_35
        default 36 if PCNT_PIN_A_GPIO_36
        default 39 if PCNT_PIN_A_GPIO_39

    # Выбор для пина A ******************************************************************************************

    # Выбор для пина B ******************************************************************************************

